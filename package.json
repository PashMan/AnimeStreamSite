{
  "name": "animestream",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "start": "node server.ts",
    "build": "npm run sitemap && vite build",
    "build:staging": "npm run sitemap && vite build --mode staging",
    "preview": "vite preview",
    "preview:staging": "wrangler pages dev dist",
    "deploy:staging": "wrangler pages deploy dist --branch staging",
    "deploy:prod": "wrangler pages deploy dist --branch main",
    "lint": "tsc --noEmit",
    "sitemap": "tsx scripts/generate-sitemap.ts",
    "sitemap:remove": "tsx scripts/generate-remove-sitemap.ts",
    "generate-seo": "tsx scripts/generate-seo.ts"
  },
  "dependencies": {
    "@google/genai": "^1.46.0",
    "@supabase/supabase-js": "^2.97.0",
    "anime-parsers-js": "^1.0.11",
    "artplayer": "^5.4.0",
    "axios": "^1.13.6",
    "browser-image-compression": "^2.0.2",
    "dotenv": "^17.3.1",
    "groq-sdk": "^1.1.1",
    "hls.js": "^1.6.15",
    "hono": "^4.12.9",
    "kodikwrapper": "^3.0.6",
    "lucide-react": "^0.344.0",
    "motion": "^12.34.3",
    "rc-slider": "^11.1.9",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-helmet-async": "^2.0.5",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^6.22.3",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.1",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260301.1",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/node": "^25.3.0",
    "@types/react": "^18.2.64",
    "@types/react-dom": "^18.2.21",
    "@vitejs/plugin-react": "^5.1.4",
    "autoprefixer": "^10.4.24",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.21.0",
    "typescript": "^5.2.2",
    "vite": "^7.3.1",
    "wrangler": "^4.73.0"
  }
}
